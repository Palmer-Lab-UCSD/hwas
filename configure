#!/bin/sh
#
#
# Generated by Claude Opus 4.7 on April 23, 2026 by Robert Vogel
#
#
# configure detect htslib for the hwas R package

# Prefer user-supplied values
if [ -n "$HTSLIB_CFLAGS" ] && [ -n "$HTSLIB_LIBS" ]; then
    echo "Using HTSLIB_CFLAGS='$HTSLIB_CFLAGS' HTSLIB_LIBS='$HTSLIB_LIBS' from environment"
else
    if command -v pkg-config >/dev/null 2>&1 && pkg-config --exists htslib; then
        HTSLIB_CFLAGS=$(pkg-config --cflags htslib)
        HTSLIB_LIBS=$(pkg-config --libs htslib)
        echo "Found htslib via pkg-config: $HTSLIB_CFLAGS $HTSLIB_LIBS"
    else
        echo "ERROR: htslib not found." >&2
        echo "  Install htslib and ensure pkg-config can find it," >&2
        echo "  or set HTSLIB_CFLAGS and HTSLIB_LIBS before installing." >&2
        exit 1
    fi
fi

# Substitute into Makevars.in
sed -e "s|@HTSLIB_CFLAGS@|${HTSLIB_CFLAGS}|g" \
    -e "s|@HTSLIB_LIBS@|${HTSLIB_LIBS}|g" \
    src/Makevars.in > src/Makevars

exit 0
